<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">SmartEDU</a>
        <div class="collapse navbar-collapse" id="navbars-host">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/"><i class="fa fa-home"></i> Home</a></li>
                
                <!-- Giriş yapınca görünecekler -->
                <li class="nav-item d-none" id="dashboardItem"><a class="nav-link" href="/users/dashboard"><i class="fa fa-tachometer-alt"></i> Dashboard</a></li>
                <li class="nav-item d-none" id="logoutItem"><a class="nav-link" href="#" id="logoutLink"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                
                <!-- Giriş yapmayınca görünecekler -->
                <li class="nav-item d-none" id="loginItem"><a class="nav-link" href="/login"><i class="fa fa-sign-in-alt"></i> Login</a></li>
                <li class="nav-item d-none" id="registerItem"><a class="nav-link" href="/register"><i class="fa fa-user-plus"></i> Register</a></li>
            </ul>
        </div>
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const token = localStorage.getItem('accessToken');
        const dItem = document.getElementById('dashboardItem');
        const lOut = document.getElementById('logoutItem');
        const lIn = document.getElementById('loginItem');
        const rItem = document.getElementById('registerItem');

        if (token) {
            dItem.classList.remove('d-none');
            lOut.classList.remove('d-none');
        } else {
            lIn.classList.remove('d-none');
            rItem.classList.remove('d-none');
        }

        document.getElementById('logoutLink')?.addEventListener('click', async (e) => {
            e.preventDefault();
            await fetch('/users/logout', { 
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('accessToken') }
            });
            localStorage.clear();
            window.location.href = '/login';
        });
    });
</script>