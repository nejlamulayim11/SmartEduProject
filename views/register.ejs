<%- include('partials/_header'); -%>
<%- include('partials/_navigation'); -%>

<div class="container">
    <div class="section-title text-center">
        <h3 class="mt-5">REGISTER</h3>

        <div class="row">
            <div class="col-xl-12 col-md-12 col-sm-12">
                <div class="contact_form">
                    <!-- Hata ve başarı mesajlarının görüneceği yer -->
                    <div id="message"></div>
                    
                    <!-- action ve method yerine id veriyoruz -->
                    <form id="registerForm" novalidate>
                        <div class="row row-fluid">
                            <div class="offset-1 col-lg-10 col-md-10 col-sm-10">
                                <input type="text" name="name" id="name" class="form-control" placeholder="Name" required>
                            </div>
                            <div class="offset-1 col-lg-10 col-md-10 col-sm-10">
                                <input type="email" name="email" id="email" class="form-control" placeholder="Email" required>
                            </div>
                            <div class="offset-1 col-lg-10 col-md-10 col-sm-10">
                                <input type="password" name="password" id="password" class="form-control" placeholder="Password" required>
                            </div>
                            <div class="offset-1 col-lg-10 col-md-10 col-sm-10">
                                <select name="role" id="role" class="form-control">
                                    <option value="student">Student</option>
                                    <option value="teacher">Teacher</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                            <div class="offset-1 col-lg-10 col-md-10 col-sm-10">
                                <button type="submit" class="btn btn-light btn-radius btn-brd grd1 btn-block">REGISTER</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const messageDiv = document.getElementById('message');
        const formData = {
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            password: document.getElementById('password').value,
            role: document.getElementById('role').value
        };

        const response = await fetch('/users/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });

        const data = await response.json();

        if (data.status === 'success') {
            // Başarılı ise login'e yönlendir
            window.location.href = data.redirect;
        } else {
            // Hata varsa mesajı ekrana bas
            messageDiv.innerHTML = `<div class="alert alert-danger">${data.message || 'Kayıt başarısız'}</div>`;
        }
    });
</script>

<%- include('partials/_footer'); -%>